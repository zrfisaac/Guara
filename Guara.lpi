<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <PathDelim Value="\"/>
    <General>
      <SessionStorage Value="InProjectDir"/>
      <AutoCreateForms Value="False"/>
      <Title Value="Guara"/>
      <Scaled Value="True"/>
      <ResourceType Value="res"/>
      <UseXPManifest Value="True"/>
      <XPManifest>
        <DpiAware Value="True"/>
      </XPManifest>
      <Icon Value="0"/>
    </General>
    <VersionInfo>
      <UseVersionInfo Value="True"/>
      <RevisionNr Value="1"/>
      <StringTable Comments="zrfisaac.project.Guara" CompanyName="Isaac Caires / zrfisaac.github.io" FileDescription="A versatile database management tool for seamless data export, import, SQL scripting, and format conversion across multiple database systems." InternalName="zrfisaac.project.Guara" LegalCopyright="Isaac Caires / zrfisaac.github.io" LegalTrademarks="Isaac Caires / zrfisaac.github.io" OriginalFilename="Guara" ProductName="Guara" ProductVersion="0.0.1.0"/>
    </VersionInfo>
    <BuildModes>
      <Item Name="Debug" Default="True"/>
    </BuildModes>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
    <RunParams>
      <FormatVersion Value="2"/>
    </RunParams>
    <RequiredPackages>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="Guara.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="Sources\model_base.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="ModelBase"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
      </Unit>
      <Unit>
        <Filename Value="Sources\menu_main.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="MenuMain"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
      </Unit>
      <Unit>
        <Filename Value="Sources\model_menu.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="ModelMenu"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
      </Unit>
      <Unit>
        <Filename Value="Sources\model_module.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="ModelModule"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="DataModule"/>
      </Unit>
      <Unit>
        <Filename Value="Sources\module_main.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="ModuleMain"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="DataModule"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <PathDelim Value="\"/>
    <Target>
      <Filename Value="Binaries/Debug/Guara"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="$(ProjOutDir)"/>
      <OtherUnitFiles Value="Sources"/>
      <UnitOutputDirectory Value="Objects\Debug"/>
    </SearchPaths>
    <Linking>
      <Debugging>
        <DebugInfoType Value="dsDwarf3"/>
      </Debugging>
      <Options>
        <Win32>
          <GraphicApplication Value="True"/>
        </Win32>
      </Options>
    </Linking>
  </CompilerOptions>
  <Debugging>
    <Exceptions>
      <Item>
        <Name Value="EAbort"/>
      </Item>
      <Item>
        <Name Value="ECodetoolError"/>
      </Item>
      <Item>
        <Name Value="EFOpenError"/>
      </Item>
    </Exceptions>
  </Debugging>
</CONFIG>
